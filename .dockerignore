# Build artifacts — rebuilt inside the image.
/_build/
/deps/
/doc/
/.fetch
/assets/node_modules
node_modules

# Mix / release artifacts.
erl_crash.dump
*.ez
malan-*.tar

# Compiled assets — built during the image build.
/priv/static/assets
/priv/static/cache_manifest.json

# Local Postgres state — must never reach an image.
pg_passwd
pgdata/

# VCS / CI metadata — not used by the runtime image.
.git
.gitignore
.gitattributes
.github

# Editor / LSP / agent caches.
.elixir_ls
.codex
.claude
.vscode
.idea

# Editor swap and backup files.
*.swp
*.swo
*.bk
*.bk.2

# Test / coverage artifacts.
cover/

# Planning, design, and security review docs at the repo root. None of the
# Dockerfiles COPY *.md today; excluding keeps the build context lean and
# protects against a future wide COPY pulling in untracked drafts.
*.md
!README.md

# Local-only data files and dev-only scripts not used by the build.
images.json
priv/repo/grant_permissions.sql
scripts/curl/

# Logs.
*.log
